# Database
DATABASE_URL=mysql://user:password@localhost:3306/optimearn

# JWT/Session
JWT_SECRET=your-super-secret-jwt-key-change-this

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# Frontend Clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Optional: Manus (if still using some Manus features)
VITE_APP_ID=your_app_id
OAUTH_SERVER_URL=https://oauth.manus.im
OWNER_OPEN_ID=your_owner_open_id

# Optional: File Storage (Manus Forge)
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# Postback Security
POSTBACK_SECRET=your-postback-webhook-secret

# Node Environment
NODE_ENV=production

# Analytics (Optional)
VITE_ANALYTICS_ENDPOINT=https://your-analytics-domain.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id
